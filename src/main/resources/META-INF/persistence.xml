<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="BW5-mezziPubblici">
        <class>entities.Biglietto</class>
        <class>entities.Abbonamento</class>
        <class>entities.Acquisto</class>
        <class>entities.Tratta</class>
        <class>entities.Percorrenza</class>
        <class>entities.StatoMezzo</class>
        <class>entities.Mezzo</class>
        <class>entities.User</class>
        <class>entities.Tessera</class>
        <class>entities.PuntoDiVendita</class>
        <class>entities.Rivenditore</class>
        <class>entities.DistributoreAutomatico</class>
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/BW5-mezziPubblici"/>
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
        </properties>
    </persistence-unit>
</persistence>